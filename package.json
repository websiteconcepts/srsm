{
  "name": "srsm-events",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && wrangler dev",
    "deploy": "npm run build:css && wrangler deploy",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --watch",
    "db:migrate:local": "wrangler d1 migrations apply srsm-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply srsm-db --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wrangler": "^4.83.0"
  }
}
